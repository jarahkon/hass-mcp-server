# Hass MCP Server
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Optional — required only for file management tools (upload, download, etc.)
# Install the "Advanced SSH & Web Terminal" app in HA first.
# Username MUST be "root" when SFTP is enabled (app limitation).
HA_SSH_HOST=homeassistant.local
HA_SSH_PORT=22
HA_SSH_USER=root

# Authentication: use EITHER a private key (recommended) OR a password.
# The PRIVATE key stays here; the PUBLIC key (.pub) goes into the HA app's authorized_keys config.
HA_SSH_KEY_PATH=C:/Users/you/.ssh/ha_ed25519
# HA_SSH_PASSWORD=your_ssh_password_here
