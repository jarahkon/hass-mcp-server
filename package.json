{
  "name": "hass-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for full Home Assistant control — dashboards, files, automations, add-ons, and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hass-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "check": "tsc --noEmit && eslint src/",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "mcp",
    "home-assistant",
    "lovelace",
    "dashboard",
    "automation"
  ],
  "license": "MIT",
  "author": "jarahkon",
  "repository": "github:jarahkon/hass-mcp-server",
  "homepage": "https://github.com/jarahkon/hass-mcp-server",
  "bugs": "https://github.com/jarahkon/hass-mcp-server/issues",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ssh2-sftp-client": "^12.1.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/ws": "^8.18.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
